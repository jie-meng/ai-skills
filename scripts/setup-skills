#!/bin/bash
# Setup Skills - Copy skills from this repository to AI assistant config directories

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
SOURCE_SKILLS_DIR="$PROJECT_ROOT/skills"

# Tool registry: "label|config_dir|skills_subpath"
# config_dir is relative to $HOME unless it starts with .config/
TOOLS=(
    "Copilot CLI|.copilot|skills"
    "Claude Code|.claude|skills"
    "Cursor|.cursor|skills"
    "Codex|.codex|skills"
    "Gemini CLI|.gemini|skills"
    "Qwen CLI|.qwen|skills"
    "iFlow CLI|.iflow|skills"
    "Opencode|.config/opencode|skills"
)

validate_source() {
    if [ ! -d "$SOURCE_SKILLS_DIR" ]; then
        echo -e "${RED}Error: Source skills directory not found: $SOURCE_SKILLS_DIR${NC}"
        exit 1
    fi
    if [ -z "$(ls -A "$SOURCE_SKILLS_DIR" 2>/dev/null)" ]; then
        echo -e "${RED}Error: Source skills directory is empty: $SOURCE_SKILLS_DIR${NC}"
        exit 1
    fi
}

get_tool_config_path() {
    local config_dir="$1"
    echo "$HOME/$config_dir"
}

sync_skills() {
    local label="$1"
    local config_dir="$2"
    local skills_subpath="$3"
    local config_path
    config_path="$(get_tool_config_path "$config_dir")"
    local target_skills_dir="$config_path/$skills_subpath"

    if [ ! -d "$config_path" ]; then
        echo -e "${YELLOW}⚠ $label is not installed (~/$config_dir not found), skipping.${NC}"
        return 1
    fi

    if [ ! -d "$target_skills_dir" ]; then
        echo -e "${YELLOW}Creating skills directory: $target_skills_dir${NC}"
        mkdir -p "$target_skills_dir"
    fi

    local added_skills=()
    local updated_skills=()

    for source_skill in "$SOURCE_SKILLS_DIR"/*; do
        [ -d "$source_skill" ] || continue
        local skill_name
        skill_name="$(basename "$source_skill")"
        local target_skill="$target_skills_dir/$skill_name"

        if [ ! -d "$target_skill" ]; then
            added_skills+=("$skill_name")
        elif ! diff -qr "$source_skill" "$target_skill" >/dev/null 2>&1; then
            updated_skills+=("$skill_name")
        fi
    done

    for source_skill in "$SOURCE_SKILLS_DIR"/*; do
        [ -d "$source_skill" ] || continue
        local skill_name_copy
        skill_name_copy="$(basename "$source_skill")"
        rm -rf "$target_skills_dir/$skill_name_copy"
        cp -r "$source_skill" "$target_skills_dir/$skill_name_copy"
    done

    echo -e "${GREEN}✓ [$label] Skills synced to $target_skills_dir${NC}"

    if [ ${#added_skills[@]} -gt 0 ]; then
        echo -e "  ${GREEN}Added:${NC} ${added_skills[*]}"
    fi
    if [ ${#updated_skills[@]} -gt 0 ]; then
        echo -e "  ${YELLOW}Updated:${NC} ${updated_skills[*]}"
    fi
    if [ ${#added_skills[@]} -eq 0 ] && [ ${#updated_skills[@]} -eq 0 ]; then
        echo "  No skill changes detected."
    fi
    return 0
}

show_menu() {
    echo ""
    echo -e "${BOLD}Select an AI tool to install skills:${NC}"
    echo ""
    for i in "${!TOOLS[@]}"; do
        IFS='|' read -r label _ _ <<< "${TOOLS[$i]}"
        echo -e "  ${CYAN}$((i + 1))${NC}. $label"
    done
    echo ""
    echo -e "  ${CYAN}0${NC}. All"
    echo ""
}

install_all() {
    local installed=0
    local skipped=0

    for entry in "${TOOLS[@]}"; do
        IFS='|' read -r label config_dir skills_subpath <<< "$entry"
        if sync_skills "$label" "$config_dir" "$skills_subpath"; then
            ((installed++))
        else
            ((skipped++))
        fi
        echo ""
    done

    echo -e "${BOLD}Done.${NC} Installed: ${GREEN}$installed${NC}, Skipped: ${YELLOW}$skipped${NC}"
}

install_by_index() {
    local idx="$1"
    local entry="${TOOLS[$idx]}"
    IFS='|' read -r label config_dir skills_subpath <<< "$entry"
    sync_skills "$label" "$config_dir" "$skills_subpath"
}

# --- Main ---

validate_source

if [ -n "$1" ]; then
    # Direct target mode (e.g. ./scripts/setup-skills .copilot)
    TARGET_DIR="$1"
    TARGET_PATH="$HOME/$TARGET_DIR"

    if [ ! -d "$TARGET_PATH" ]; then
        echo -e "${RED}Error: ~/$TARGET_DIR not found. The tool does not appear to be installed.${NC}"
        exit 1
    fi

    TARGET_SKILLS_DIR="$TARGET_PATH/skills"
    if [ ! -d "$TARGET_SKILLS_DIR" ]; then
        echo -e "${YELLOW}Creating skills directory: $TARGET_SKILLS_DIR${NC}"
        mkdir -p "$TARGET_SKILLS_DIR"
    fi

    added_skills=()
    updated_skills=()

    for source_skill in "$SOURCE_SKILLS_DIR"/*; do
        [ -d "$source_skill" ] || continue
        skill_name="$(basename "$source_skill")"
        target_skill="$TARGET_SKILLS_DIR/$skill_name"

        if [ ! -d "$target_skill" ]; then
            added_skills+=("$skill_name")
        elif ! diff -qr "$source_skill" "$target_skill" >/dev/null 2>&1; then
            updated_skills+=("$skill_name")
        fi
    done

    for source_skill in "$SOURCE_SKILLS_DIR"/*; do
        [ -d "$source_skill" ] || continue
        skill_name="$(basename "$source_skill")"
        rm -rf "$TARGET_SKILLS_DIR/$skill_name"
        cp -r "$source_skill" "$TARGET_SKILLS_DIR/$skill_name"
    done

    echo -e "${GREEN}✓ Skills synced to $TARGET_SKILLS_DIR${NC}"

    if [ ${#added_skills[@]} -gt 0 ]; then
        echo -e "${GREEN}Added skills:${NC} ${added_skills[*]}"
    fi
    if [ ${#updated_skills[@]} -gt 0 ]; then
        echo -e "${YELLOW}Updated skills:${NC} ${updated_skills[*]}"
    fi
    if [ ${#added_skills[@]} -eq 0 ] && [ ${#updated_skills[@]} -eq 0 ]; then
        echo "No skill changes detected."
    fi

    exit 0
fi

# Interactive menu mode
show_menu

read -rp "Enter your choice: " choice

if ! [[ "$choice" =~ ^[0-9]+$ ]]; then
    echo -e "${RED}Error: Please enter a number.${NC}"
    exit 1
fi

echo ""

if [ "$choice" -eq 0 ]; then
    install_all
elif [ "$choice" -ge 1 ] && [ "$choice" -le ${#TOOLS[@]} ]; then
    install_by_index $((choice - 1))
else
    echo -e "${RED}Error: Invalid choice. Please enter 0-${#TOOLS[@]}.${NC}"
    exit 1
fi
